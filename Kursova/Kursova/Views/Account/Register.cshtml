@model Kursova.Models.RegisterViewModel
@{
    ViewData["Title"] = "Регистрация";
}

<div class="auth-container d-flex align-items-center justify-content-center">
    <div class="auth-card glass-effect p-5">
        <h2 class="text-center mb-4 auth-title">Создать аккаунт</h2>
        <form asp-controller="Account" asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            
            <div class="form-floating mb-3 custom-input-group">
                <input asp-for="Email" class="form-control" id="floatingEmail" placeholder="name@example.com" />
                <label asp-for="Email" for="floatingEmail">Email</label>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            
            <div class="form-floating mb-3 custom-input-group">
                <input asp-for="Password" class="form-control" id="floatingPassword" placeholder="Пароль" />
                <label asp-for="Password" for="floatingPassword">Пароль</label>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-4 custom-input-group">
                <input asp-for="ConfirmPassword" class="form-control" id="floatingConfirmPassword" placeholder="Подтвердите пароль" />
                <label asp-for="ConfirmPassword" for="floatingConfirmPassword">Подтвердите пароль</label>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            
            <button type="submit" class="btn btn-primary w-100 btn-glow py-2 fw-bold rounded-pill">Зарегистрироваться</button>
            
            <div class="text-center mt-4">
                <p class="text-muted mb-0">Уже есть аккаунт? <a asp-action="Login" class="text-decoration-none fw-bold auth-link">Войти</a></p>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
