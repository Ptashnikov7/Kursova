@{
    ViewData["Title"] = "Доступ запрещен";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 text-center">
            <div class="card border-0 shadow-lg p-5" style="border-radius: 20px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px);">
                <div class="mb-4">
                    <i class="bi bi-shield-lock-fill text-danger" style="font-size: 5rem;"></i>
                </div>
                <h1 class="display-4 fw-bold text-dark">403</h1>
                <h2 class="h4 mb-4 text-secondary">У вас недостаточно прав для просмотра этой страницы.</h2>
                <p class="text-muted mb-5">
                    Пожалуйста, обратитесь к администратору, если вы считаете, что это ошибка, или вернитесь на главную страницу.
                </p>
                <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg px-4 gap-3 rounded-pill shadow-sm">
                        <i class="bi bi-house-door me-2"></i>На главную
                    </a>
                    <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg px-4 rounded-pill shadow-sm">
                        Войти под другим аккаунтом
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }
        .card {
            transition: transform 0.3s ease;
        }
        .card:hover {
            transform: translateY(-5px);
        }
    </style>
}
