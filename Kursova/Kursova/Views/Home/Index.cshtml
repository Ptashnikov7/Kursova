@{
    ViewData["Title"] = "Главная";
}

<div id="app" v-cloak>
    <!-- Hero Section -->
    <div class="hero-section text-center py-5 mb-5 glass-effect rounded-4 shadow-sm">
        <h1 class="display-4 fw-bold hero-title">Свежие продукты с доставкой</h1>
        <p class="lead text-muted mb-4">Натурально, вкусно, быстро.</p>
        <button class="btn btn-primary btn-glow rounded-pill px-4 py-2 fw-bold" @@click="scrollToProducts">К покупкам</button>
    </div>

    <div class="row" id="products-section">
        <!-- Products List -->
        <div class="col-md-8">
            <h3 class="mb-4 fw-bold">Наши товары</h3>
            <div class="row g-4">
                <div class="col-sm-6 col-lg-4" v-for="product in products" :key="product.id">
                    <div class="card h-100 product-card border-0 shadow-sm glass-effect">
                        <div class="product-img-wrapper">
                            <img :src="product.imageUrl || 'https://via.placeholder.com/300'" class="card-img-top product-img" :alt="product.name">
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">{{ product.name }}</h5>
                            <p class="card-text text-muted small flex-grow-1">{{ product.description }}</p>
                            <div class="d-flex justify-content-between align-items-center mt-3">
                                <span class="fw-bold text-primary fs-5">{{ product.price.toFixed(2) }} грн</span>
                                <button @@click="addToCart(product)" class="btn btn-sm btn-primary rounded-circle btn-glow cart-btn">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart-plus" viewBox="0 0 16 16">
                                      <path d="M9 5.5a.5.5 0 0 0-1 0V7H6.5a.5.5 0 0 0 0 1H8v1.5a.5.5 0 0 0 1 0V8h1.5a.5.5 0 0 0 0-1H9z"/>
                                      <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0zm7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div v-if="loading" class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Загрузка...</span>
                </div>
            </div>
        </div>

        <!-- Shopping Cart (Reactive) -->
        <div class="col-md-4 mt-5 mt-md-0">
            <div class="cart-sidebar glass-effect p-4 rounded-4 shadow-sm position-sticky" style="top: 20px;">
                <h3 class="mb-4 fw-bold d-flex justify-content-between align-items-center">
                    Корзина
                    <span class="badge bg-primary rounded-pill">{{ cartItemCount }}</span>
                </h3>
                
                <div v-if="cart.length === 0" class="text-center text-muted py-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-cart mb-3 opacity-50" viewBox="0 0 16 16">
                      <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5zM3.102 4l1.313 7h8.17l1.313-7H3.102zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4zm-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/>
                    </svg>
                    <p>Ваша корзина пуста</p>
                </div>

                <div v-else>
                    <ul class="list-group list-group-flush mb-3 cart-list">
                        <li class="list-group-item bg-transparent d-flex justify-content-between lh-sm py-3 px-0 border-bottom" v-for="(item, index) in cart" :key="index">
                            <div>
                                <h6 class="my-0 fw-bold">{{ item.product.name }}</h6>
                                <small class="text-muted">{{ item.product.price.toFixed(2) }} грн x {{ item.quantity }}</small>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-muted">{{ (item.product.price * item.quantity).toFixed(2) }} грн</span>
                                <button class="btn btn-sm btn-outline-danger border-0" @@click="removeFromCart(index)">
                                    &times;
                                </button>
                            </div>
                        </li>
                    </ul>
                    <div class="d-flex justify-content-between mb-4 border-top pt-3">
                        <span class="fw-bold">Итого (грн)</span>
                        <strong class="text-primary fs-5">{{ cartTotal.toFixed(2) }} грн</strong>
                    </div>
                    <button class="btn btn-primary w-100 btn-glow rounded-pill fw-bold py-2" @@click="checkout">Оформить заказ</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.js"></script>
    <script>
        const { createApp } = Vue

        createApp({
            data() {
                return {
                    products: [],
                    cart: [],
                    loading: true
                }
            },
            computed: {
                cartItemCount() {
                    return this.cart.reduce((total, item) => total + item.quantity, 0);
                },
                cartTotal() {
                    return this.cart.reduce((total, item) => total + (item.product.price * item.quantity), 0);
                }
            },
            mounted() {
                this.fetchProducts();
                // Load cart from local storage if needed
                const savedCart = localStorage.getItem('grocery_cart');
                if (savedCart) {
                    this.cart = JSON.parse(savedCart);
                }
            },
            watch: {
                cart: {
                    handler(newCart) {
                        localStorage.setItem('grocery_cart', JSON.stringify(newCart));
                    },
                    deep: true
                }
            },
            methods: {
                async fetchProducts() {
                    try {
                        const response = await fetch('/api/products');
                        if (response.ok) {
                            this.products = await response.json();
                        }
                    } catch (error) {
                        console.error('Error fetching products:', error);
                    } finally {
                        this.loading = false;
                    }
                },
                addToCart(product) {
                    const existingItem = this.cart.find(item => item.product.id === product.id);
                    if (existingItem) {
                        existingItem.quantity++;
                    } else {
                        this.cart.push({ product: product, quantity: 1 });
                    }
                },
                removeFromCart(index) {
                    this.cart.splice(index, 1);
                },
                scrollToProducts() {
                    document.getElementById('products-section').scrollIntoView({ behavior: 'smooth' });
                },
                async checkout() {
                    if (this.cart.length === 0) return;
                    
                    const payload = this.cart.map(item => ({
                        id: item.product.id,
                        name: item.product.name,
                        price: item.product.price,
                        quantity: item.quantity
                    }));

                    try {
                        const response = await fetch('/api/checkout/create-session', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify(payload)
                        });

                        const data = await response.json();
                        if (response.ok && data.url) {
                            window.location.href = data.url;
                        } else {
                            alert('Ошибка при создании сессии оплаты: ' + (data.error || 'Неизвестная ошибка'));
                        }
                    } catch (error) {
                        console.error('Ошибка при оплате:', error);
                        alert('Произошла ошибка при попытке оплаты.');
                    }
                }
            }
        }).mount('#app')
    </script>
    <style>
        [v-cloak] { display: none; }
    </style>
}
