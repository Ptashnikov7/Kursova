@model IEnumerable<Kursova.Models.Product>
@{
    ViewData["Title"] = "Управление товарами";
}

<div class="admin-dashboard mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управление товарами</h2>
        <a asp-action="Create" class="btn btn-primary rounded-pill btn-glow">Добавить новый товар</a>
    </div>

    <div class="card glass-effect border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0 admin-table">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Изображение</th>
                            <th>@Html.DisplayNameFor(model => model.Name)</th>
                            <th>@Html.DisplayNameFor(model => model.Price)</th>
                            <th class="pe-4 text-end">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model) {
                            <tr class="align-middle">
                                <td class="ps-4">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl)) {
                                        <img src="@item.ImageUrl" alt="@item.Name" class="product-img-sm rounded-circle" style="width: 50px; height: 50px; object-fit: cover;"/>
                                    } else {
                                        <div class="bg-secondary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                            <span>No Img</span>
                                        </div>
                                    }
                                </td>
                                <td class="fw-bold">@Html.DisplayFor(modelItem => item.Name)</td>
                                <td>@Html.DisplayFor(modelItem => item.Price) грн</td>
                                <td class="pe-4 text-end">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Редактировать</a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Удалить</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
